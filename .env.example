# Database
POSTGRES_USER=familycare
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=familycare_db
DATABASE_URL=postgresql://familycare:your_password_here@postgres:5432/familycare_db

# Redis
REDIS_URL=redis://redis:6379

# JWT - Change these in production!
JWT_ACCESS_SECRET=change_me_in_production
JWT_REFRESH_SECRET=change_me_in_production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# API
API_PORT=4000
NODE_ENV=development
WEB_URL=http://localhost:3000

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# AI (optional - leave empty to use mock mode)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Stripe (optional - leave empty to use mock payment mode)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
