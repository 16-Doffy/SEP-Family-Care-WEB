{
  "name": "family-care",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "prisma", "unrs-resolver"]
  },
  "scripts": {
    "dev": "docker compose -f docker-compose.yml -f docker-compose.override.yml up",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:seed": "pnpm --filter api db:seed",
    "db:studio": "pnpm --filter api db:studio",
    "build": "pnpm --filter shared build && pnpm --filter api build && pnpm --filter web build",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up --build"
  }
}
