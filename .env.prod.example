# Database
POSTGRES_USER=familycare
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=familycare_db
DATABASE_URL=postgresql://familycare:CHANGE_THIS_STRONG_PASSWORD@postgres:5432/familycare_db

# Redis
REDIS_URL=redis://redis:6379

# JWT - Use long random strings in production!
JWT_ACCESS_SECRET=CHANGE_THIS_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_THIS_64_CHAR_RANDOM_STRING
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# API
API_PORT=4000
NODE_ENV=production
WEB_URL=https://yourdomain.com

# Web (must match the domain browsers will use)
NEXT_PUBLIC_API_URL=https://yourdomain.com:4000
NEXT_PUBLIC_SOCKET_URL=https://yourdomain.com:4000

# AI (optional - leave empty to use mock mode)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Stripe (optional - leave empty to use mock payment mode)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
