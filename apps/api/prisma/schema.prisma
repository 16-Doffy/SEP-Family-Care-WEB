generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  PARENT
  CHILD
}

enum Plan {
  FREE
  BASIC
  PREMIUM
}

enum WalletType {
  JOINT
  PERSONAL
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  TASK_REWARD
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_SUBMITTED
  TASK_APPROVED
  TASK_REJECTED
  TRANSFER_RECEIVED
  MEMBER_JOINED
  CHAT_MESSAGE
  SOS
  MONEY_REQUEST
  MONEY_RESOLVED
  SYSTEM
}

enum ConversationType {
  GROUP
  PRIVATE
}

enum MessageType {
  TEXT
  IMAGE
  LOCATION
}

enum SosStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
  FALSE_ALARM
}

enum MoneyRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String
  avatarUrl    String?
  role         Role     @default(CHILD)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  familyMember             FamilyMember?
  refreshTokens            RefreshToken[]
  notifications            Notification[]
  taskProofs               TaskProof[]
  conversationParticipants ConversationParticipant[]
  sentMessages             Message[]
  sosAlerts                SosAlert[]               @relation("SentSOS")
  resolvedSosAlerts        SosAlert[]               @relation("ResolvedSOS")

  @@index([email])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Family {
  id        String   @id @default(cuid())
  name      String
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       FamilyMember[]
  wallets       Wallet[]
  tasks         Task[]
  conversations Conversation[]
  events        FamilyEvent[]
  sosAlerts     SosAlert[]
  moneyRequests MoneyRequest[]
  albumPhotos   AlbumPhoto[]
}

model FamilyMember {
  id       String   @id @default(cuid())
  userId   String   @unique
  familyId String
  nickname String?
  joinedAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  family       Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  wallet       Wallet?       @relation("PersonalWallet")
  assignedTasks Task[]       @relation("AssignedTasks")
  createdTasks  Task[]       @relation("CreatedTasks")
  createdEvents FamilyEvent[]
  moneyRequests         MoneyRequest[] @relation("RequestedMoney")
  resolvedMoneyRequests MoneyRequest[] @relation("ResolvedMoneyRequest")
  uploadedAlbumPhotos   AlbumPhoto[]

  @@index([familyId])
}

model Wallet {
  id        String     @id @default(cuid())
  familyId  String
  name      String
  type      WalletType
  balance   Decimal    @default(0) @db.Decimal(15, 2)
  currency  String     @default("VND")
  ownerId   String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  family               Family        @relation(fields: [familyId], references: [id])
  owner                FamilyMember? @relation("PersonalWallet", fields: [ownerId], references: [id])
  sentTransactions     Transaction[] @relation("FromWallet")
  receivedTransactions Transaction[] @relation("ToWallet")

  @@index([familyId])
}

model Transaction {
  id           String          @id @default(cuid())
  fromWalletId String?
  toWalletId   String?
  amount       Decimal         @db.Decimal(15, 2)
  type         TransactionType
  description  String?
  taskId       String?
  createdAt    DateTime        @default(now())

  fromWallet Wallet? @relation("FromWallet", fields: [fromWalletId], references: [id])
  toWallet   Wallet? @relation("ToWallet", fields: [toWalletId], references: [id])
  task       Task?   @relation(fields: [taskId], references: [id])

  @@index([fromWalletId])
  @@index([toWalletId])
  @@index([createdAt])
}

model Task {
  id           String     @id @default(cuid())
  familyId     String
  title        String
  description  String?
  status       TaskStatus @default(PENDING)
  reward       Decimal?   @db.Decimal(15, 2)
  dueDate      DateTime?
  createdById  String
  assignedToId String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  family       Family        @relation(fields: [familyId], references: [id])
  createdBy    FamilyMember  @relation("CreatedTasks", fields: [createdById], references: [id])
  assignedTo   FamilyMember? @relation("AssignedTasks", fields: [assignedToId], references: [id])
  proofs       TaskProof[]
  transactions Transaction[]

  @@index([familyId, status])
  @@index([assignedToId])
}

model TaskProof {
  id          String   @id @default(cuid())
  taskId      String
  submittedBy String
  imageUrl    String?
  note        String?
  createdAt   DateTime @default(now())

  task      Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  submitter User @relation(fields: [submittedBy], references: [id])

  @@index([taskId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model Conversation {
  id        String           @id @default(cuid())
  familyId  String
  type      ConversationType @default(GROUP)
  name      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  family       Family                   @relation(fields: [familyId], references: [id])
  participants ConversationParticipant[]
  messages     Message[]

  @@index([familyId])
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime @default(now())
  joinedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  senderId       String
  type           MessageType @default(TEXT)
  content        String
  metadata       Json?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
}

model FamilyEvent {
  id          String    @id @default(cuid())
  familyId    String
  createdById String
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean   @default(false)
  color       String    @default("#3b82f6")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  family    Family       @relation(fields: [familyId], references: [id])
  createdBy FamilyMember @relation(fields: [createdById], references: [id])

  @@index([familyId, startDate])
}

model SosAlert {
  id           String    @id @default(cuid())
  familyId     String
  senderId     String
  latitude     Float?
  longitude    Float?
  address      String?
  message      String?
  status       SosStatus @default(ACTIVE)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  resolvedAt   DateTime?
  resolvedById String?

  family     Family @relation(fields: [familyId], references: [id])
  sender     User   @relation("SentSOS", fields: [senderId], references: [id])
  resolvedBy User?  @relation("ResolvedSOS", fields: [resolvedById], references: [id])

  @@index([familyId, status])
  @@index([senderId])
  @@index([createdAt])
}

model MoneyRequest {
  id           String             @id @default(cuid())
  familyId     String
  requesterId  String
  amount       Decimal            @db.Decimal(15, 2)
  reason       String?
  status       MoneyRequestStatus @default(PENDING)
  note         String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  resolvedAt   DateTime?
  resolvedById String?

  family     Family       @relation(fields: [familyId], references: [id])
  requester  FamilyMember @relation("RequestedMoney", fields: [requesterId], references: [id])
  resolvedBy FamilyMember? @relation("ResolvedMoneyRequest", fields: [resolvedById], references: [id])

  @@index([familyId, status])
  @@index([requesterId])
  @@index([createdAt])
}

model AlbumPhoto {
  id         String   @id @default(cuid())
  familyId   String
  uploaderId String
  imageUrl   String
  caption    String?
  createdAt  DateTime @default(now())

  family   Family       @relation(fields: [familyId], references: [id])
  uploader FamilyMember @relation(fields: [uploaderId], references: [id])

  @@index([familyId, createdAt])
  @@index([uploaderId])
}
