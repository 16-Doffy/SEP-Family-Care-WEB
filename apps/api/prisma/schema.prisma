// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phoneNumber  String?  @unique
  passwordHash String
  displayName  String
  avatarUrl    String?
  role         Role     @default(FAMILY_MEMBER)
  userType     UserType @default(NORMAL_USER)
  accountStatus AccountStatus @default(ACTIVE)
  verificationStatus VerificationStatus @default(VERIFIED)
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  familyMember             FamilyMember?
  createdFamilies          Family[]                  @relation("WorkspaceCreator")
  authSessions             AuthSession[]
  acceptedInvitations      FamilyInvite[]            @relation("InvitationAcceptedBy")
  passwordResetTokens      PasswordResetToken[]
  notifications            Notification[]
  taskProofs               TaskProof[]
  conversationParticipants ConversationParticipant[]
  sentMessages             Message[]
  sosAlerts                SosAlert[]                @relation("SentSOS")
  resolvedSosAlerts        SosAlert[]                @relation("ResolvedSOS")
  locationShare            LocationShare?
  aiConversation           AiConversation?
  ownedDevices             Device[]                  @relation("DeviceOwner")
  routePoints              DeviceRoutePoint[]
  createdProvisioningLogs  WorkspaceProvisioningLog[] @relation("ProvisioningCreator")

  @@index([email])
}

// ERD `AuthSession` — một phiên đăng nhập / refresh token của user.
model AuthSession {
  id         String    @id @default(cuid())
  token      String    @unique
  userId     String
  // device_info / ip_address: bối cảnh phiên (mobile/browser/device).
  deviceInfo Json?
  ipAddress  String?
  // is_revoked / revoked_at: thu hồi phiên trước khi hết hạn.
  isRevoked  Boolean   @default(false)
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([isRevoked])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Family {
  id                    String             @id @default(cuid())
  name                  String
  description           String?
  avatarUrl             String?
  createdByUserId       String?
  plan                  Plan               @default(FREE)
  planId                String?
  status                FamilyStatus       @default(ACTIVE)
  activationStatus      FamilyProvisionStatus @default(READY)
  statusReason          String?
  lockedAt              DateTime?
  subscriptionStatus    SubscriptionStatus @default(ACTIVE)
  subscriptionStartedAt DateTime?
  subscriptionExpiresAt DateTime?
  // Onboarding state: chưa active cho đến khi mua gói thành công.
  activatedAt           DateTime?
  // Bước onboarding hiện tại: WORKSPACE_CREATED | PLAN_SELECTED | PAYMENT_VERIFIED | ACTIVE
  onboardingStep        String             @default("WORKSPACE_CREATED")
  stripeCustomerId      String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  createdBy              User?                    @relation("WorkspaceCreator", fields: [createdByUserId], references: [id])
  subscriptionPlan       SubscriptionPlan?       @relation(fields: [planId], references: [id])
  workspaceSubscriptions WorkspaceSubscription[]
  subscriptionPayments   SubscriptionPayment[]
  provisioningLogs       WorkspaceProvisioningLog[]
  members                FamilyMember[]
  wallets                Wallet[]
  financeLedgers         FinanceLedger[]
  financeModels          FinanceModel[]
  financeCategories      FinanceCategory[]
  budgetPlans            BudgetPlan[]
  financialGoals         FinancialGoal[]
  spendingSupportRequests SpendingSupportRequest[]
  budgetAlerts           BudgetAlert[]
  tasks                  Task[]
  taskCategories         TaskCategory[]
  conversations          Conversation[]
  events                 FamilyEvent[]
  sosAlerts              SosAlert[]
  moneyRequests          MoneyRequest[]
  albumPhotos            AlbumPhoto[]
  albumCategories        AlbumCategory[]
  locationShares         LocationShare[]
  devices                Device[]
  deviceRoutePoints      DeviceRoutePoint[]
  payments               Payment[]
  invites                FamilyInvite[]
  announcements          Announcement[]
  provision              FamilyProvision?
  budgets                FamilyBudget[]
  familyExpenses         FamilyExpense[]
  fundSnapshots          MonthlyFundSnapshot[]
  recurringTaskTemplates RecurringTaskTemplate[]
  sosSetting             SOSSetting?
  emergencyWearables     WearableDevice[]
  memberLocationPoints   MemberLocationPoint[]
  sosLocationPoints      SOSLocationPoint[]
  sensorEvents           SensorEvent[]
  sosResponses           SOSResponse[]
  notifications          Notification[]
  aiConversations        AiConversation[]

  @@index([createdByUserId])
  @@index([planId])
  @@index([status])
  @@index([subscriptionStatus, subscriptionExpiresAt])
}

model FamilyProvision {
  id            String                @id @default(cuid())
  familyId      String                @unique
  status        FamilyProvisionStatus @default(PENDING)
  containerName String?
  databaseName  String?
  imageTag      String?
  metadata      Json?
  lastError     String?
  provisionedAt DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([status])
}

// ERD `family_invitations`. `code` ≡ invitation_token, `role` ≡ assigned_role,
// `relationship` ≡ assigned_relationship, `expiresAt` ≡ expired_at.
model FamilyInvite {
  id                String                 @id @default(cuid())
  code              String                 @unique
  familyId          String
  invitedEmail      String?
  invitedPhone      String?
  role              Role
  relationship      FamilyRelationship     @default(OTHER)
  status            FamilyInvitationStatus @default(PENDING)
  createdByMemberId String?
  acceptedByUserId  String?
  usedAt            DateTime?
  acceptedAt        DateTime?
  expiresAt         DateTime
  createdAt         DateTime               @default(now())

  family     Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  createdBy  FamilyMember? @relation("InvitationCreatedBy", fields: [createdByMemberId], references: [id], onDelete: SetNull)
  acceptedBy User?         @relation("InvitationAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([familyId])
  @@index([code, expiresAt, usedAt])
  @@index([status])
  @@index([invitedEmail])
  @@index([createdByMemberId])
  @@index([acceptedByUserId])
}

model SubscriptionPlan {
  id               String   @id @default(cuid())
  code             String   @unique
  name             String
  description      String?
  price            Decimal  @default(0) @db.Decimal(12, 2)
  priceMonthly     Decimal? @db.Decimal(12, 2)
  priceYearly      Decimal? @db.Decimal(12, 2)
  currency         String   @default("VND")
  billingPeriod    String   @default("MONTHLY")
  // Thời hạn sử dụng tính theo ngày (vd: 30, 90, 365). null = vô thời hạn (LIFETIME).
  durationDays     Int?
  // Giới hạn tài nguyên
  maxMembers       Int?
  maxTasksPerMonth Int?
  // Dung lượng (MB). null = không giới hạn.
  albumStorageMb   Int?
  systemStorageMb  Int?
  // Quyền sử dụng AI: tổng quát + AI tài chính (gói cao mới có)
  aiEnabled        Boolean  @default(false)
  aiFinanceEnabled Boolean  @default(false)
  // Trợ lý lập kế hoạch tài chính nâng cao
  advancedReports  Boolean  @default(false)
  prioritySupport  Boolean  @default(false)
  // Bậc gói: 0 = free, 1 = basic, 2 = standard, 3 = premium...
  tier             Int      @default(0)
  features         Json     @default("[]")
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  families               Family[]
  workspaceSubscriptions WorkspaceSubscription[]
  subscriptionPayments   SubscriptionPayment[]

  @@index([isActive, sortOrder])
}

model WorkspaceSubscription {
  id          String             @id @default(cuid())
  familyId    String
  planId      String
  status      SubscriptionStatus @default(ACTIVE)
  startedAt   DateTime          @default(now())
  expiresAt   DateTime?
  activatedAt DateTime?
  canceledAt  DateTime?
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  family   Family                @relation(fields: [familyId], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan      @relation(fields: [planId], references: [id])
  payments SubscriptionPayment[]

  @@index([familyId, status])
  @@index([planId])
}

model SubscriptionPayment {
  id              String        @id @default(cuid())
  familyId        String
  subscriptionId  String?
  planId          String?
  paymentId       String?       @unique
  amount          Decimal       @db.Decimal(15, 2)
  currency        String        @default("VND")
  status          PaymentStatus @default(PENDING)
  paymentType     SubscriptionPaymentType @default(NEW_SUBSCRIPTION)
  provider        String        @default("MOCK")
  providerRef     String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  family       Family                 @relation(fields: [familyId], references: [id], onDelete: Cascade)
  subscription WorkspaceSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  plan         SubscriptionPlan?      @relation(fields: [planId], references: [id], onDelete: SetNull)
  payment      Payment?               @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([familyId, createdAt])
  @@index([subscriptionId])
  @@index([planId])
}

model WorkspaceProvisioningLog {
  id              String                 @id @default(cuid())
  familyId        String
  actionType      ProvisioningActionType @default(CREATE)
  status          FamilyProvisionStatus
  message         String?
  metadata        Json?
  startedAt       DateTime?
  finishedAt      DateTime?
  createdByUserId String?
  createdAt       DateTime               @default(now())

  family    Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("ProvisioningCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([familyId, createdAt])
  @@index([status])
  @@index([createdByUserId])
}

model FamilyMember {
  id           String             @id @default(cuid())
  userId       String             @unique
  familyId     String
  displayName  String?
  familyRole   FamilyRole         @default(FAMILY_MEMBER)
  nickname     String?
  relationship FamilyRelationship @default(OTHER)
  memberStatus MemberStatus       @default(ACTIVE)
  birthDate    DateTime?
  notes        String?
  isOwner      Boolean            @default(false)
  joinedAt     DateTime           @default(now())
  leftAt       DateTime?

  // Core flow 1 — quản lý tài chính cá nhân
  occupation             String?
  hasIncome              Boolean  @default(false)
  plannedMonthlyIncome   Decimal  @default(0) @db.Decimal(15, 2)
  plannedPersonalExpense Decimal  @default(0) @db.Decimal(15, 2)
  personalSpendingLimit  Decimal? @db.Decimal(15, 2)

  user                      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  family                    Family                  @relation(fields: [familyId], references: [id], onDelete: Cascade)
  wallet                    Wallet?                 @relation("PersonalWallet")
  financeLedgers            FinanceLedger[]
  ledgerEntries             LedgerEntry[]           @relation("LedgerRecorder")
  financeModelsCreated      FinanceModel[]          @relation("FinanceModelCreator")
  goalsCreated              FinancialGoal[]         @relation("GoalCreator")
  supportRequests           SpendingSupportRequest[] @relation("SupportRequester")
  reviewedSupportRequests   SpendingSupportRequest[] @relation("SupportReviewer")
  budgetPlansCreated        BudgetPlan[]            @relation("BudgetPlanCreator")
  goalAllocations           GoalAllocation[]        @relation("GoalAllocationActor")
  taskAssignments           TaskAssignment[]        @relation("TaskAssignedTo")
  taskAssignmentsGiven      TaskAssignment[]        @relation("TaskAssignedBy")
  taskSubmissions           TaskSubmission[]        @relation("TaskSubmittedBy")
  taskReviews               TaskSubmission[]        @relation("TaskReviewedBy")
  taskUnavailabilities      TaskUnavailability[]    @relation("TaskUnavailabilityReporter")
  handledUnavailabilities   TaskUnavailability[]    @relation("TaskUnavailabilityHandler")
  rewardSettlementsReceived RewardSettlement[]      @relation("RewardReceiver")
  rewardSettlementsSettled  RewardSettlement[]      @relation("RewardSettler")
  rewardAllocations         RewardAllocation[]      @relation("RewardAllocationActor")
  rewardDisputesReported    RewardDispute[]         @relation("RewardDisputeReporter")
  rewardDisputesResolved    RewardDispute[]         @relation("RewardDisputeResolver")
  sosSettingsCreated        SOSSetting[]            @relation("SosSettingCreator")
  emergencyWearables        WearableDevice[]
  memberLocationPoints      MemberLocationPoint[]
  sosAlertsTriggered        SosAlert[]              @relation("TriggeredSOSMember")
  sosAlertsResolved         SosAlert[]              @relation("ResolvedSOSMember")
  sosResponses              SOSResponse[]
  assignedTasks             Task[]                  @relation("AssignedTasks")
  createdTasks              Task[]                  @relation("CreatedTasks")
  originalAssignedTasks     Task[]                  @relation("OriginalAssignedTasks")
  createdEvents             FamilyEvent[]
  moneyRequests             MoneyRequest[]          @relation("RequestedMoney")
  resolvedMoneyRequests     MoneyRequest[]          @relation("ResolvedMoneyRequest")
  uploadedAlbumPhotos       AlbumPhoto[]
  managedAlbumCategories    AlbumCategory[]
  announcements             Announcement[]
  incomeSources             IncomeSource[]
  actualIncomes             ActualIncome[]
  personalExpenses          PersonalExpense[]
  familyExpensePayments     FamilyExpense[]         @relation("ExpensePayer")
  recurringTemplatesDefault RecurringTaskTemplate[] @relation("RecurringDefaultAssignee")
  recurringTemplatesCreated RecurringTaskTemplate[] @relation("RecurringCreator")
  monthlyFinances           MemberMonthlyFinance[]
  notifications             Notification[]
  conversationsCreated      Conversation[]          @relation("ConversationCreator")
  calendarParticipations    CalendarEventParticipant[]
  albumTagsReceived         AlbumMediaTag[]         @relation("AlbumTagSubject")
  albumTagsGiven            AlbumMediaTag[]         @relation("AlbumTagAuthor")
  aiConversations           AiConversation[]
  invitationsCreated        FamilyInvite[]          @relation("InvitationCreatedBy")

  @@index([familyId])
}

model Wallet {
  id        String     @id @default(cuid())
  familyId  String
  name      String
  type      WalletType
  balance   Decimal    @default(0) @db.Decimal(15, 2)
  currency  String     @default("VND")
  ownerId   String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  family               Family        @relation(fields: [familyId], references: [id])
  owner                FamilyMember? @relation("PersonalWallet", fields: [ownerId], references: [id])
  sentTransactions     Transaction[] @relation("FromWallet")
  receivedTransactions Transaction[] @relation("ToWallet")

  @@index([familyId])
}

model Transaction {
  id           String          @id @default(cuid())
  fromWalletId String?
  toWalletId   String?
  amount       Decimal         @db.Decimal(15, 2)
  type         TransactionType
  description  String?
  taskId       String?
  createdAt    DateTime        @default(now())

  fromWallet      Wallet?          @relation("FromWallet", fields: [fromWalletId], references: [id])
  toWallet        Wallet?          @relation("ToWallet", fields: [toWalletId], references: [id])
  task            Task?            @relation(fields: [taskId], references: [id])
  personalExpense PersonalExpense? @relation("PersonalExpenseTx")
  familyExpense   FamilyExpense?   @relation("FamilyExpenseTx")
  actualIncome    ActualIncome?    @relation("ActualIncomeTx")

  @@index([fromWalletId])
  @@index([toWalletId])
  @@index([createdAt])
}

model FinanceLedger {
  id            String              @id @default(cuid())
  familyId      String
  ownerMemberId String?
  name          String
  type          FinanceLedgerType   @default(FAMILY_SHARED)
  status        FinanceLedgerStatus @default(ACTIVE)
  currency      String              @default("VND")
  openingAmount Decimal             @default(0) @db.Decimal(15, 2)
  note          String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  family      Family         @relation(fields: [familyId], references: [id], onDelete: Cascade)
  ownerMember FamilyMember?  @relation(fields: [ownerMemberId], references: [id], onDelete: SetNull)
  entries     LedgerEntry[]
  jars        FinanceJar[]
  goals       FinancialGoal[]

  @@index([familyId, type])
  @@index([ownerMemberId])
}

model LedgerEntry {
  id                String                 @id @default(cuid())
  ledgerId          String
  recordedById      String?
  categoryId        String?
  budgetLineId      String?
  goalId            String?
  jarId             String?
  supportRequestId  String?
  rewardSettlementId String?
  type              LedgerEntryType
  amount            Decimal                @db.Decimal(15, 2)
  currency          String                 @default("VND")
  title             String
  description       String?
  // entryDate ≡ ERD `occurred_at` (ngày phát sinh).
  entryDate         DateTime               @default(now())
  status            LedgerEntryStatus      @default(ACTIVE)
  essentialType     EssentialType          @default(NA)
  sourceType        FinanceEntrySourceType @default(MANUAL)
  // source_id: liên kết polymorphic (support_request / reward_settlement / AI-OCR). Không FK cứng.
  sourceId          String?
  metadata          Json?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  ledger           FinanceLedger          @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  recordedBy       FamilyMember?          @relation("LedgerRecorder", fields: [recordedById], references: [id], onDelete: SetNull)
  category         FinanceCategory?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  budgetLine       BudgetLine?            @relation(fields: [budgetLineId], references: [id], onDelete: SetNull)
  goal             FinancialGoal?         @relation(fields: [goalId], references: [id], onDelete: SetNull)
  jar              FinanceJar?            @relation(fields: [jarId], references: [id], onDelete: SetNull)
  supportRequest   SpendingSupportRequest? @relation(fields: [supportRequestId], references: [id], onDelete: SetNull)
  rewardSettlement RewardSettlement?      @relation(fields: [rewardSettlementId], references: [id], onDelete: SetNull)
  goalAllocations  GoalAllocation[]
  rewardAllocations RewardAllocation[]

  @@index([ledgerId, entryDate])
  @@index([recordedById])
  @@index([categoryId])
  @@index([jarId])
  @@index([supportRequestId])
  @@index([rewardSettlementId])
  @@index([sourceType, sourceId])
}

model FinanceModel {
  id          String             @id @default(cuid())
  familyId    String
  createdById String?
  name        String
  type        FinanceModelType   @default(CUSTOM)
  status      FinanceModelStatus @default(ACTIVE)
  description String?
  metadata    Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  family    Family          @relation(fields: [familyId], references: [id], onDelete: Cascade)
  createdBy FamilyMember?   @relation("FinanceModelCreator", fields: [createdById], references: [id], onDelete: SetNull)
  jars      FinanceJar[]

  @@index([familyId, status])
  @@index([createdById])
}

model FinanceJar {
  id              String             @id @default(cuid())
  modelId         String
  ledgerId        String?
  name            String
  description     String?
  // purpose: mô tả mục đích lọ/quỹ (vd: thiết yếu, tiết kiệm, giáo dục...).
  purpose         String?
  // allocationRatio ≡ ERD `allocation_percent` (0–100).
  allocationRatio Decimal            @default(0) @db.Decimal(5, 2)
  targetAmount    Decimal?           @db.Decimal(15, 2)
  thresholdAmount Decimal?           @db.Decimal(15, 2)
  thresholdPercent Decimal?          @db.Decimal(5, 2)
  visibilityScope VisibilityScope    @default(FAMILY)
  status          FinanceModelStatus @default(ACTIVE)
  color           String             @default("#2563eb")
  sortOrder       Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  model             FinanceModel       @relation(fields: [modelId], references: [id], onDelete: Cascade)
  ledger            FinanceLedger?     @relation(fields: [ledgerId], references: [id], onDelete: SetNull)
  ledgerEntries     LedgerEntry[]
  budgetLines       BudgetLine[]
  defaultForCategories FinanceCategory[] @relation("CategoryDefaultJar")
  relatedGoals      FinancialGoal[]    @relation("GoalRelatedJar")
  budgetAlerts      BudgetAlert[]
  rewardAllocations RewardAllocation[]

  @@index([modelId, sortOrder])
  @@index([ledgerId])
  @@index([status])
}

model FinanceCategory {
  id                  String              @id @default(cuid())
  familyId            String
  name                String
  type                FinanceCategoryType
  defaultJarId        String?
  defaultEssentialType EssentialType?
  status              FinanceModelStatus  @default(ACTIVE)
  color               String              @default("#64748b")
  icon                String?
  isSystem            Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  family          Family                   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  defaultJar      FinanceJar?              @relation("CategoryDefaultJar", fields: [defaultJarId], references: [id], onDelete: SetNull)
  entries         LedgerEntry[]
  budgetLines     BudgetLine[]
  supportRequests SpendingSupportRequest[]
  budgetAlerts    BudgetAlert[]

  @@unique([familyId, name, type])
  @@index([familyId, type])
  @@index([defaultJarId])
}

model BudgetPlan {
  id          String           @id @default(cuid())
  familyId    String
  createdById String?
  name        String
  periodType  BudgetPeriodType @default(MONTHLY)
  startDate   DateTime
  endDate     DateTime?
  expectedSharedIncome  Decimal? @db.Decimal(15, 2)
  expectedSharedExpense Decimal? @db.Decimal(15, 2)
  status      BudgetPlanStatus @default(ACTIVE)
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  family    Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  createdBy FamilyMember? @relation("BudgetPlanCreator", fields: [createdById], references: [id], onDelete: SetNull)
  lines     BudgetLine[]
  alerts    BudgetAlert[]

  @@index([familyId, status])
  @@index([createdById])
}

model BudgetLine {
  id             String       @id @default(cuid())
  budgetPlanId   String
  categoryId     String?
  jarId          String?
  name           String
  plannedAmount  Decimal      @db.Decimal(15, 2)
  actualAmount   Decimal      @default(0) @db.Decimal(15, 2)
  thresholdAmount Decimal?    @db.Decimal(15, 2)
  thresholdPercent Decimal?   @db.Decimal(5, 2)
  essentialType  EssentialType @default(NA)
  note           String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  budgetPlan BudgetPlan       @relation(fields: [budgetPlanId], references: [id], onDelete: Cascade)
  category   FinanceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  jar        FinanceJar?      @relation(fields: [jarId], references: [id], onDelete: SetNull)
  entries    LedgerEntry[]

  @@index([budgetPlanId])
  @@index([categoryId])
  @@index([jarId])
}

model FinancialGoal {
  id              String              @id @default(cuid())
  familyId        String
  ledgerId        String?
  createdById     String?
  title           String
  description     String?
  targetAmount    Decimal             @db.Decimal(15, 2)
  currentAmount   Decimal             @default(0) @db.Decimal(15, 2)
  monthlyContributionTarget Decimal?  @db.Decimal(15, 2)
  relatedJarId    String?
  // targetDate ≡ ERD `deadline`.
  targetDate      DateTime?
  status          FinancialGoalStatus @default(ACTIVE)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  family      Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  ledger      FinanceLedger?   @relation(fields: [ledgerId], references: [id], onDelete: SetNull)
  relatedJar  FinanceJar?      @relation("GoalRelatedJar", fields: [relatedJarId], references: [id], onDelete: SetNull)
  createdBy   FamilyMember?    @relation("GoalCreator", fields: [createdById], references: [id], onDelete: SetNull)
  allocations GoalAllocation[]
  entries     LedgerEntry[]
  alerts      BudgetAlert[]
  rewardAllocations RewardAllocation[]

  @@index([familyId, status])
  @@index([ledgerId])
  @@index([relatedJarId])
  @@index([createdById])
}

model GoalAllocation {
  id            String   @id @default(cuid())
  goalId        String
  actorId       String?
  ledgerEntryId String?
  amount        Decimal  @db.Decimal(15, 2)
  note          String?
  allocatedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  goal        FinancialGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  actor       FamilyMember? @relation("GoalAllocationActor", fields: [actorId], references: [id], onDelete: SetNull)
  ledgerEntry LedgerEntry?  @relation(fields: [ledgerEntryId], references: [id], onDelete: SetNull)

  @@index([goalId, allocatedAt])
  @@index([actorId])
  @@index([ledgerEntryId])
}

model SpendingSupportRequest {
  id           String                       @id @default(cuid())
  familyId     String
  requesterId  String
  reviewedById String?
  categoryId   String?
  amount       Decimal                      @db.Decimal(15, 2)
  // reason giữ nguyên; purpose ≡ ERD `purpose` (mục đích chi tiêu).
  reason       String?
  purpose      String?
  status       SpendingSupportRequestStatus @default(PENDING)
  // managerNote giữ nguyên; decisionNote ≡ ERD `decision_note`.
  managerNote  String?
  decisionNote String?
  reviewedAt   DateTime?
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt

  family     Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  requester  FamilyMember     @relation("SupportRequester", fields: [requesterId], references: [id])
  reviewedBy FamilyMember?    @relation("SupportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  category   FinanceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  entries    LedgerEntry[]

  @@index([familyId, status])
  @@index([requesterId])
  @@index([reviewedById])
  @@index([categoryId])
}

model BudgetAlert {
  id             String          @id @default(cuid())
  familyId       String
  budgetPlanId   String?
  goalId         String?
  jarId          String?
  categoryId     String?
  type           BudgetAlertType
  severity       AlertSeverity   @default(MEDIUM)
  status         AlertStatus     @default(NEW)
  title          String
  message        String?
  thresholdValue Decimal?        @db.Decimal(15, 2)
  actualValue    Decimal?        @db.Decimal(15, 2)
  metadata       Json?
  createdAt      DateTime        @default(now())
  resolvedAt     DateTime?

  family     Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  budgetPlan BudgetPlan?      @relation(fields: [budgetPlanId], references: [id], onDelete: SetNull)
  goal       FinancialGoal?   @relation(fields: [goalId], references: [id], onDelete: SetNull)
  jar        FinanceJar?      @relation(fields: [jarId], references: [id], onDelete: SetNull)
  category   FinanceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([familyId, status])
  @@index([budgetPlanId])
  @@index([goalId])
  @@index([jarId])
  @@index([categoryId])
}

model Task {
  id           String     @id @default(cuid())
  familyId     String
  categoryId   String?
  title        String
  description  String?
  taskType     TaskType   @default(AD_HOC)
  priority     TaskPriority @default(MEDIUM)
  status       TaskStatus @default(PENDING)
  reward       Decimal?   @db.Decimal(15, 2)
  dueDate      DateTime?
  createdById  String
  assignedToId String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Recurring task linkage (core flow 2)
  templateId         String?
  scheduledDate      DateTime?
  isOpenForClaim     Boolean   @default(false)
  originalAssigneeId String?

  family           Family                 @relation(fields: [familyId], references: [id])
  category         TaskCategory?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy        FamilyMember           @relation("CreatedTasks", fields: [createdById], references: [id])
  assignedTo       FamilyMember?          @relation("AssignedTasks", fields: [assignedToId], references: [id])
  originalAssignee FamilyMember?          @relation("OriginalAssignedTasks", fields: [originalAssigneeId], references: [id])
  template         RecurringTaskTemplate? @relation(fields: [templateId], references: [id])
  proofs           TaskProof[]
  transactions     Transaction[]
  assignments      TaskAssignment[]
  submissions      TaskSubmission[]
  rewardSetting    RewardSetting?
  rewardSettlements RewardSettlement[]
  schedule         TaskSchedule?

  @@index([familyId, status])
  @@index([categoryId])
  @@index([assignedToId])
  @@index([templateId, scheduledDate])
}

model TaskProof {
  id          String   @id @default(cuid())
  taskId      String
  submissionId String?
  submittedBy String
  proofType   ProofType @default(IMAGE)
  imageUrl    String?
  fileUrl     String?
  thumbnailUrl String?
  note        String?
  createdAt   DateTime @default(now())

  task       Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  submission TaskSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  submitter  User            @relation(fields: [submittedBy], references: [id])

  @@index([taskId])
  @@index([submissionId])
}

model TaskCategory {
  id          String   @id @default(cuid())
  familyId    String
  name        String
  description String?
  color       String   @default("#2563eb")
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  tasks  Task[]

  @@unique([familyId, name])
  @@index([familyId, isActive])
}

model TaskAssignment {
  id           String           @id @default(cuid())
  taskId       String
  assignedToId String
  assignedById String?
  status       AssignmentStatus @default(ASSIGNED)
  assignedAt   DateTime         @default(now())
  dueAt        DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  task       Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignedTo FamilyMember  @relation("TaskAssignedTo", fields: [assignedToId], references: [id])
  assignedBy FamilyMember? @relation("TaskAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  submissions TaskSubmission[]
  unavailabilities TaskUnavailability[]

  @@unique([taskId, assignedToId])
  @@index([assignedToId, status])
  @@index([assignedById])
}

model TaskSubmission {
  id           String           @id @default(cuid())
  taskId       String
  assignmentId String?
  submittedById String
  reviewedById String?
  status       SubmissionStatus @default(WAITING_REVIEW)
  note         String?
  reviewNote   String?
  submittedAt  DateTime         @default(now())
  reviewedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  task        Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignment  TaskAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  submittedBy FamilyMember    @relation("TaskSubmittedBy", fields: [submittedById], references: [id])
  reviewedBy  FamilyMember?   @relation("TaskReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  proofs      TaskProof[]
  rewardSettlement RewardSettlement?

  @@index([taskId, status])
  @@index([assignmentId])
  @@index([submittedById])
  @@index([reviewedById])
}

model TaskUnavailability {
  id           String                 @id @default(cuid())
  assignmentId String?
  memberId     String
  handledById  String?
  reason       String?
  status       UnavailabilityStatus   @default(REPORTED)
  reportedAt   DateTime               @default(now())
  handledAt    DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  assignment TaskAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  member     FamilyMember    @relation("TaskUnavailabilityReporter", fields: [memberId], references: [id])
  handledBy  FamilyMember?   @relation("TaskUnavailabilityHandler", fields: [handledById], references: [id], onDelete: SetNull)

  @@index([assignmentId])
  @@index([memberId, status])
  @@index([handledById])
}

model RewardSetting {
  id                   String     @id @default(cuid())
  taskId               String     @unique
  rewardType           RewardType @default(MONEY_RECORD)
  amount               Decimal?   @db.Decimal(15, 2)
  pointValue           Int?
  description          String?
  autoCreateSettlement Boolean    @default(true)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  task        Task               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  settlements RewardSettlement[]
}

model RewardSettlement {
  id               String                 @id @default(cuid())
  taskId           String?
  taskSubmissionId String?                @unique
  rewardSettingId  String?
  receiverId       String
  settledById      String?
  amount           Decimal?               @db.Decimal(15, 2)
  rewardType       RewardType             @default(MONEY_RECORD)
  status           RewardSettlementStatus @default(PENDING_SETTLEMENT)
  externalMethod   ExternalSettlementMethod?
  note             String?
  externalNote     String?
  dueAt            DateTime?
  settledAt        DateTime?
  confirmedAt      DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  task          Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  taskSubmission TaskSubmission? @relation(fields: [taskSubmissionId], references: [id], onDelete: SetNull)
  rewardSetting RewardSetting?  @relation(fields: [rewardSettingId], references: [id], onDelete: SetNull)
  receiver      FamilyMember    @relation("RewardReceiver", fields: [receiverId], references: [id])
  settledBy     FamilyMember?   @relation("RewardSettler", fields: [settledById], references: [id], onDelete: SetNull)
  allocations   RewardAllocation[]
  disputes      RewardDispute[]
  ledgerEntries LedgerEntry[]

  @@unique([taskId, receiverId])
  @@index([taskId])
  @@index([rewardSettingId])
  @@index([receiverId, status])
  @@index([settledById])
}

model RewardAllocation {
  id            String   @id @default(cuid())
  settlementId  String
  actorId       String?
  jarId         String?
  goalId        String?
  ledgerEntryId String?
  amount        Decimal? @db.Decimal(15, 2)
  points        Int?
  note          String?
  createdAt     DateTime @default(now())

  settlement  RewardSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  actor       FamilyMember?    @relation("RewardAllocationActor", fields: [actorId], references: [id], onDelete: SetNull)
  jar         FinanceJar?      @relation(fields: [jarId], references: [id], onDelete: SetNull)
  goal        FinancialGoal?   @relation(fields: [goalId], references: [id], onDelete: SetNull)
  ledgerEntry LedgerEntry?     @relation(fields: [ledgerEntryId], references: [id], onDelete: SetNull)

  @@index([settlementId])
  @@index([actorId])
  @@index([jarId])
  @@index([goalId])
  @@index([ledgerEntryId])
}

model RewardDispute {
  id            String              @id @default(cuid())
  settlementId  String
  reportedById  String
  resolvedById  String?
  status        RewardDisputeStatus @default(OPEN)
  reason        String?
  resolution    String?
  createdAt     DateTime            @default(now())
  resolvedAt    DateTime?

  settlement RewardSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  reportedBy FamilyMember     @relation("RewardDisputeReporter", fields: [reportedById], references: [id])
  resolvedBy FamilyMember?    @relation("RewardDisputeResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([settlementId, status])
  @@index([reportedById])
  @@index([resolvedById])
}

model Notification {
  id         String               @id @default(cuid())
  userId     String
  familyId   String?
  memberId   String?
  type       NotificationType
  title      String
  body       String
  // source_type / source_id: liên kết polymorphic tới task/reward/finance/sos... (không FK cứng).
  sourceType String?
  sourceId   String?
  priority   NotificationPriority @default(NORMAL)
  isRead     Boolean              @default(false)
  metadata   Json?
  createdAt  DateTime             @default(now())

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  family Family?       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  member FamilyMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@index([familyId])
  @@index([memberId])
  @@index([createdAt])
}

model Conversation {
  id                String             @id @default(cuid())
  familyId          String
  createdByMemberId String?
  type              ConversationType   @default(GROUP)
  name              String?
  status            ConversationStatus @default(ACTIVE)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  family       Family                    @relation(fields: [familyId], references: [id])
  createdBy    FamilyMember?             @relation("ConversationCreator", fields: [createdByMemberId], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages     Message[]

  @@index([familyId])
  @@index([createdByMemberId])
}

model ConversationParticipant {
  id                String                        @id @default(cuid())
  conversationId    String
  userId            String
  participantStatus ConversationParticipantStatus @default(ACTIVE)
  lastReadAt        DateTime                      @default(now())
  joinedAt          DateTime                      @default(now())
  leftAt            DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  senderId       String
  type           MessageType @default(TEXT)
  content        String
  metadata       Json?
  createdAt      DateTime    @default(now())
  editedAt       DateTime?
  deletedAt      DateTime?

  conversation Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                @relation(fields: [senderId], references: [id])
  attachments  MessageAttachment[]

  @@index([conversationId, createdAt])
}

model FamilyEvent {
  id           String              @id @default(cuid())
  familyId     String
  createdById  String
  title        String
  description  String?
  location     String?
  startDate    DateTime
  endDate      DateTime?
  allDay       Boolean             @default(false)
  isRecurring  Boolean             @default(false)
  status       CalendarEventStatus @default(ACTIVE)
  color        String              @default("#3b82f6")
  reminderSent Boolean             @default(false)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  family       Family                     @relation(fields: [familyId], references: [id])
  createdBy    FamilyMember               @relation(fields: [createdById], references: [id])
  participants CalendarEventParticipant[]

  @@index([familyId, startDate])
}

model SosAlert {
  id           String    @id @default(cuid())
  familyId     String
  senderId     String
  triggeredByMemberId String?
  latitude     Float?
  longitude    Float?
  address      String?
  message      String?
  severity     AlertSeverity @default(HIGH)
  source       RouteSource @default(MOBILE_APP)
  deviceId     String?
  wearableDeviceId String?
  fallDetected Boolean @default(false)
  status       SosStatus @default(ACTIVE)
  triggeredAt  DateTime @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  resolvedAt   DateTime?
  resolvedById String?
  resolvedByMemberId String?
  resolutionNote String?

  family           Family          @relation(fields: [familyId], references: [id])
  sender           User            @relation("SentSOS", fields: [senderId], references: [id])
  resolvedBy       User?           @relation("ResolvedSOS", fields: [resolvedById], references: [id])
  triggeredByMember FamilyMember?  @relation("TriggeredSOSMember", fields: [triggeredByMemberId], references: [id], onDelete: SetNull)
  resolvedByMember FamilyMember?   @relation("ResolvedSOSMember", fields: [resolvedByMemberId], references: [id], onDelete: SetNull)
  device           Device?         @relation(fields: [deviceId], references: [id])
  wearableDevice   WearableDevice? @relation(fields: [wearableDeviceId], references: [id], onDelete: SetNull)
  locationPoints   SOSLocationPoint[]
  responses        SOSResponse[]
  sensorEvents     SensorEvent[]     @relation("SensorEventAlert")
  createdBySensorEvents SensorEvent[] @relation("SensorCreatedAlert")

  @@index([familyId, status])
  @@index([senderId])
  @@index([triggeredByMemberId])
  @@index([deviceId])
  @@index([wearableDeviceId])
  @@index([createdAt])
}

model SOSSetting {
  id                    String   @id @default(cuid())
  familyId              String   @unique
  createdById           String?
  autoNotifyEnabled     Boolean  @default(true)
  fallDetectionEnabled  Boolean  @default(true)
  locationTrackingEnabled Boolean @default(true)
  emergencyMessage      String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  family            Family             @relation(fields: [familyId], references: [id], onDelete: Cascade)
  createdBy         FamilyMember?      @relation("SosSettingCreator", fields: [createdById], references: [id], onDelete: SetNull)
  emergencyContacts EmergencyContact[]

  @@index([createdById])
}

model EmergencyContact {
  id          String   @id @default(cuid())
  settingId   String
  name        String
  phoneNumber String?
  email       String?
  relationship FamilyRelationship @default(OTHER)
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  setting SOSSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)

  @@index([settingId, priority])
}

model WearableDevice {
  id               String                @id @default(cuid())
  familyId         String
  memberId         String?
  legacyDeviceId   String?               @unique
  name             String
  deviceCode       String                @unique
  deviceType       WearableDeviceKind    @default(SMARTWATCH)
  deviceIdentifier String?
  status           DeviceStatus          @default(PAIRED)
  pairingStatus    WearablePairingStatus @default(PAIRED)
  gpsEnabled       Boolean               @default(true)
  sosEnabled       Boolean               @default(true)
  batteryLevel     Int?
  lastSeenAt       DateTime?
  metadata         Json?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  family         Family                @relation(fields: [familyId], references: [id], onDelete: Cascade)
  member         FamilyMember?         @relation(fields: [memberId], references: [id], onDelete: SetNull)
  legacyDevice   Device?               @relation(fields: [legacyDeviceId], references: [id], onDelete: SetNull)
  sosAlerts      SosAlert[]
  sensorEvents   SensorEvent[]
  locationPoints MemberLocationPoint[]
  sosLocations   SOSLocationPoint[]

  @@index([familyId, status])
  @@index([memberId])
}

model SensorEvent {
  id               String          @id @default(cuid())
  familyId         String
  wearableDeviceId String?
  sosAlertId       String?
  // created_sos_alert_id: cảnh báo SOS được TẠO RA từ sự kiện cảm biến này (khác với sosAlertId — alert nó thuộc về).
  createdSosAlertId String?
  type             SensorEventType
  severity         AlertSeverity   @default(MEDIUM)
  // value ≡ ERD `raw_value` (dữ liệu cảm biến thô).
  value            Json?
  occurredAt       DateTime        @default(now())
  createdAt        DateTime        @default(now())

  family         Family          @relation(fields: [familyId], references: [id], onDelete: Cascade)
  wearableDevice WearableDevice? @relation(fields: [wearableDeviceId], references: [id], onDelete: SetNull)
  sosAlert       SosAlert?       @relation("SensorEventAlert", fields: [sosAlertId], references: [id], onDelete: SetNull)
  createdSosAlert SosAlert?      @relation("SensorCreatedAlert", fields: [createdSosAlertId], references: [id], onDelete: SetNull)

  @@index([familyId, occurredAt])
  @@index([wearableDeviceId, occurredAt])
  @@index([sosAlertId])
  @@index([createdSosAlertId])
}

model MemberLocationPoint {
  id               String             @id @default(cuid())
  familyId         String
  memberId         String?
  wearableDeviceId String?
  latitude         Float
  longitude        Float
  accuracy         Float?
  source           LocationSourceType @default(MOBILE_GPS)
  recordedAt       DateTime           @default(now())
  createdAt        DateTime           @default(now())

  family         Family          @relation(fields: [familyId], references: [id], onDelete: Cascade)
  member         FamilyMember?   @relation(fields: [memberId], references: [id], onDelete: SetNull)
  wearableDevice WearableDevice? @relation(fields: [wearableDeviceId], references: [id], onDelete: SetNull)

  @@index([familyId, recordedAt])
  @@index([memberId, recordedAt])
  @@index([wearableDeviceId, recordedAt])
}

model SOSLocationPoint {
  id               String             @id @default(cuid())
  familyId         String
  sosAlertId       String
  wearableDeviceId String?
  latitude         Float
  longitude        Float
  accuracy         Float?
  address          String?
  source           LocationSourceType @default(MOBILE_GPS)
  recordedAt       DateTime           @default(now())
  createdAt        DateTime           @default(now())

  family         Family          @relation(fields: [familyId], references: [id], onDelete: Cascade)
  sosAlert       SosAlert        @relation(fields: [sosAlertId], references: [id], onDelete: Cascade)
  wearableDevice WearableDevice? @relation(fields: [wearableDeviceId], references: [id], onDelete: SetNull)

  @@index([familyId, recordedAt])
  @@index([sosAlertId, recordedAt])
  @@index([wearableDeviceId])
}

model SOSResponse {
  id          String                 @id @default(cuid())
  familyId    String
  sosAlertId  String
  responderId String?
  type        SosSettingResponseType
  note        String?
  createdAt   DateTime               @default(now())

  family    Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  sosAlert  SosAlert      @relation(fields: [sosAlertId], references: [id], onDelete: Cascade)
  responder FamilyMember? @relation(fields: [responderId], references: [id], onDelete: SetNull)

  @@index([familyId, createdAt])
  @@index([sosAlertId])
  @@index([responderId])
}

model MoneyRequest {
  id           String             @id @default(cuid())
  familyId     String
  requesterId  String
  amount       Decimal            @db.Decimal(15, 2)
  reason       String?
  status       MoneyRequestStatus @default(PENDING)
  note         String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  resolvedAt   DateTime?
  resolvedById String?

  family     Family        @relation(fields: [familyId], references: [id])
  requester  FamilyMember  @relation("RequestedMoney", fields: [requesterId], references: [id])
  resolvedBy FamilyMember? @relation("ResolvedMoneyRequest", fields: [resolvedById], references: [id])

  @@index([familyId, status])
  @@index([requesterId])
  @@index([createdAt])
}

model AiConversation {
  id        String   @id @default(cuid())
  userId    String   @unique
  familyId  String?
  memberId  String?
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  family   Family?       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  member   FamilyMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  messages AiMessage[]

  @@index([familyId])
  @@index([memberId])
}

model AiMessage {
  id                String           @id @default(cuid())
  conversationId    String
  role              String
  senderType        AiSenderType?
  content           String
  relatedModule     AiRelatedModule?
  // permission_context: snapshot quyền user tại thời điểm AI trả lời.
  permissionContext Json?
  tokensUsed        Int?
  model             String?
  createdAt         DateTime         @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([relatedModule])
}

model LocationShare {
  id        String   @id @default(cuid())
  userId    String   @unique
  familyId  String
  isSharing Boolean  @default(false)
  latitude  Float?
  longitude Float?
  accuracy  Float?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId, isSharing])
}

model Payment {
  id                String        @id @default(cuid())
  familyId          String
  userId            String
  type              PaymentType
  amount            Decimal       @db.Decimal(15, 2)
  currency          String        @default("VND")
  status            PaymentStatus @default(PENDING)
  provider          String        @default("MOCK")
  providerReference String?
  description       String?
  metadata          Json?
  planId            String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  family              Family               @relation(fields: [familyId], references: [id], onDelete: Cascade)
  subscriptionPayment SubscriptionPayment?

  @@index([familyId, createdAt])
  @@index([status, type])
  @@index([createdAt])
}

model AlbumPhoto {
  id              String                @id @default(cuid())
  familyId        String
  uploaderId      String
  categoryId      String?
  mediaType       MediaType             @default(PHOTO)
  imageUrl        String
  thumbnailUrl    String?
  caption         String?
  visibilityScope VisibilityScope       @default(FAMILY)
  moderationStatus MediaModerationStatus @default(SAFE)
  // Người dùng xác nhận ảnh có thể hiển thị trong album chung hay chưa.
  isShared   Boolean  @default(true)
  // Danh sách tag do AI gợi ý hoặc người dùng xác nhận, ví dụ: ["Dad", "Trip 2026"].
  tags       Json     @default("[]")
  aiStatus   String   @default("PENDING") // PENDING | SUGGESTED | CONFIRMED | SKIPPED
  aiMetadata Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  family           Family                @relation(fields: [familyId], references: [id])
  uploader         FamilyMember          @relation(fields: [uploaderId], references: [id])
  category         AlbumCategory?        @relation(fields: [categoryId], references: [id])
  mediaTags        AlbumMediaTag[]
  moderationChecks MediaModerationCheck[]

  @@index([familyId, createdAt])
  @@index([familyId, categoryId])
  @@index([uploaderId])
}

model AlbumCategory {
  id          String   @id @default(cuid())
  familyId    String
  name        String
  description String?
  color       String   @default("#ec4899")
  ruleType    String   @default("MANUAL") // MANUAL | EVENT | MEMBER | AI_FACE | CUSTOM
  criteria    Json?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  family    Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  createdBy FamilyMember? @relation(fields: [createdById], references: [id])
  photos    AlbumPhoto[]

  @@unique([familyId, name])
  @@index([familyId, ruleType])
}

model Device {
  id           String       @id @default(cuid())
  familyId     String
  ownerUserId  String?
  name         String
  type         DeviceType   @default(SMARTWATCH)
  deviceCode   String       @unique
  status       DeviceStatus @default(PAIRED)
  batteryLevel Int?
  lastLatitude Float?
  lastLongitude Float?
  lastSeenAt   DateTime?
  sosEnabled   Boolean      @default(true)
  fallDetectionEnabled Boolean @default(true)
  locationTrackingEnabled Boolean @default(true)
  metadata     Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  family      Family             @relation(fields: [familyId], references: [id], onDelete: Cascade)
  owner       User?              @relation("DeviceOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  routePoints DeviceRoutePoint[]
  sosAlerts   SosAlert[]
  wearableDevice WearableDevice?

  @@index([familyId, status])
  @@index([ownerUserId])
}

model DeviceRoutePoint {
  id         String      @id @default(cuid())
  familyId   String
  deviceId   String
  userId     String?
  latitude   Float
  longitude  Float
  accuracy   Float?
  speed      Float?
  source     RouteSource @default(WEARABLE)
  recordedAt DateTime    @default(now())
  createdAt  DateTime    @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([familyId, recordedAt])
  @@index([deviceId, recordedAt])
  @@index([userId, recordedAt])
}

// ERD `family_announcements`. `senderId` ≡ created_by_member_id.
// title để nullable (additive) để không vỡ service tạo announcement hiện có.
model Announcement {
  id        String               @id @default(cuid())
  familyId  String
  senderId  String
  type      AnnouncementType     @default(ANNOUNCEMENT)
  title     String?
  content   String
  priority  NotificationPriority @default(NORMAL)
  status    AnnouncementStatus   @default(ACTIVE)
  createdAt DateTime             @default(now())

  family Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  sender FamilyMember @relation(fields: [senderId], references: [id])

  @@index([familyId, createdAt])
  @@index([senderId])
  @@index([status])
}

// ─── Core flow 1: Family Finance ──────────────────────────────────────────────

model IncomeSource {
  id             String           @id @default(cuid())
  memberId       String
  label          String
  sourceType     IncomeSourceType @default(SALARY)
  amountPerMonth Decimal          @db.Decimal(15, 2)
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  member FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, isActive])
}

model FamilyBudget {
  id                   String   @id @default(cuid())
  familyId             String
  month                Int
  year                 Int
  plannedSharedExpense Decimal  @default(0) @db.Decimal(15, 2)
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  family     Family                 @relation(fields: [familyId], references: [id], onDelete: Cascade)
  categories FamilyBudgetCategory[]

  @@unique([familyId, year, month])
  @@index([familyId, year, month])
}

model FamilyBudgetCategory {
  id       String  @id @default(cuid())
  budgetId String
  name     String
  amount   Decimal @db.Decimal(15, 2)

  budget FamilyBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId])
}

model PersonalExpense {
  id                 String   @id @default(cuid())
  memberId           String
  amount             Decimal  @db.Decimal(15, 2)
  category           String
  note               String?
  // Khi true: đã tạo Transaction WITHDRAWAL trừ ví cá nhân.
  // Khi false: chỉ ghi sổ thống kê, không đụng ví.
  deductedFromWallet Boolean  @default(false)
  transactionId      String?  @unique
  occurredAt         DateTime @default(now())
  createdAt          DateTime @default(now())

  member      FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation("PersonalExpenseTx", fields: [transactionId], references: [id])

  @@index([memberId, occurredAt])
}

model FamilyExpense {
  id                 String   @id @default(cuid())
  familyId           String
  category           String
  amount             Decimal  @db.Decimal(15, 2)
  note               String?
  paidById           String?
  // Khi true: đã tạo Transaction WITHDRAWAL trừ ví chung.
  deductedFromWallet Boolean  @default(false)
  transactionId      String?  @unique
  occurredAt         DateTime @default(now())
  createdAt          DateTime @default(now())

  family      Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  paidBy      FamilyMember? @relation("ExpensePayer", fields: [paidById], references: [id])
  transaction Transaction?  @relation("FamilyExpenseTx", fields: [transactionId], references: [id])

  @@index([familyId, occurredAt])
}

/// Thu nhập THỰC TẾ trong tháng — một dòng cho mỗi lần member ghi nhận
/// (lương về, freelance về, tiền thưởng...). Khác với `IncomeSource` (cố định,
/// dự kiến hàng tháng).
model ActualIncome {
  id               String           @id @default(cuid())
  memberId         String
  amount           Decimal          @db.Decimal(15, 2)
  sourceType       IncomeSourceType @default(SALARY)
  note             String?
  // Khi true: đã tạo Transaction DEPOSIT vào ví cá nhân.
  creditedToWallet Boolean          @default(false)
  transactionId    String?          @unique
  occurredAt       DateTime         @default(now())
  createdAt        DateTime         @default(now())

  member      FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation("ActualIncomeTx", fields: [transactionId], references: [id])

  @@index([memberId, occurredAt])
}

model MonthlyFundSnapshot {
  id                   String   @id @default(cuid())
  familyId             String
  year                 Int
  month                Int
  totalIncome          Decimal  @db.Decimal(15, 2)
  totalSharedExpense   Decimal  @db.Decimal(15, 2)
  totalPersonalExpense Decimal  @db.Decimal(15, 2)
  surplus              Decimal  @db.Decimal(15, 2)
  jointWalletBalance   Decimal  @db.Decimal(15, 2)
  createdAt            DateTime @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([familyId, year, month])
  @@index([familyId, year, month])
}

// ─── Core flow 2: Recurring tasks ─────────────────────────────────────────────

model RecurringTaskTemplate {
  id                String   @id @default(cuid())
  familyId          String
  title             String
  description       String?
  reward            Decimal? @db.Decimal(15, 2)
  rrule             String
  timeOfDay         String?
  defaultAssigneeId String?
  isActive          Boolean  @default(true)
  createdById       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  family          Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  defaultAssignee FamilyMember? @relation("RecurringDefaultAssignee", fields: [defaultAssigneeId], references: [id])
  createdBy       FamilyMember  @relation("RecurringCreator", fields: [createdById], references: [id])
  instances       Task[]

  @@index([familyId, isActive])
}

// ─── ERD-completion models (additive) ─────────────────────────────────────────

/// ERD `MemberMonthlyFinance` — khai báo tài chính cá nhân theo tháng của member
/// (thu nhập/chi tiêu dự kiến + thực tế). Là monthly summary, KHÔNG phải personal
/// ledger ghi từng giao dịch.
model MemberMonthlyFinance {
  id                     String                   @id @default(cuid())
  memberId               String
  periodMonth            Int
  periodYear             Int
  expectedIncome         Decimal?                 @db.Decimal(15, 2)
  actualIncome           Decimal?                 @db.Decimal(15, 2)
  expectedPersonalExpense Decimal?                @db.Decimal(15, 2)
  actualPersonalExpense  Decimal?                 @db.Decimal(15, 2)
  incomeVisibility       MonthlyFinanceVisibility @default(PRIVATE)
  expenseVisibility      MonthlyFinanceVisibility @default(PRIVATE)
  note                   String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  member FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, periodMonth, periodYear])
  @@index([memberId])
  @@index([periodYear, periodMonth])
}

/// ERD `TaskSchedule` — lịch lặp cho recurring task (bổ sung cạnh RecurringTaskTemplate).
model TaskSchedule {
  id             String             @id @default(cuid())
  taskId         String             @unique
  repeatType     TaskRepeatType     @default(WEEKLY)
  repeatInterval Int                @default(1)
  startDate      DateTime
  endDate        DateTime?
  dayOfWeek      Int?
  status         TaskScheduleStatus @default(ACTIVE)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([status])
}

/// ERD `MessageAttachment` — file đính kèm của một message.
model MessageAttachment {
  id         String   @id @default(cuid())
  messageId  String
  fileType   String
  fileUrl    String
  fileName   String?
  fileSize   Int?
  uploadedAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

/// ERD `CalendarEventParticipant` — thành viên được mời/tham gia một calendar event.
model CalendarEventParticipant {
  id              String                 @id @default(cuid())
  eventId         String
  memberId        String
  responseStatus  CalendarResponseStatus @default(INVITED)
  reminderEnabled Boolean                @default(true)
  createdAt       DateTime               @default(now())

  event  FamilyEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([eventId, memberId])
  @@index([eventId])
  @@index([memberId])
}

/// ERD `AlbumMediaTag` — gắn thẻ thủ công thành viên trong một media.
model AlbumMediaTag {
  id              String   @id @default(cuid())
  mediaId         String
  taggedMemberId  String
  taggedByMemberId String
  tagNote         String?
  createdAt       DateTime @default(now())

  media        AlbumPhoto   @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  taggedMember FamilyMember @relation("AlbumTagSubject", fields: [taggedMemberId], references: [id], onDelete: Cascade)
  taggedBy     FamilyMember @relation("AlbumTagAuthor", fields: [taggedByMemberId], references: [id], onDelete: Cascade)

  @@unique([mediaId, taggedMemberId])
  @@index([mediaId])
  @@index([taggedMemberId])
  @@index([taggedByMemberId])
}

/// ERD `MediaModerationCheck` — kết quả kiểm duyệt media (sensitive content / face grouping).
model MediaModerationCheck {
  id              String           @id @default(cuid())
  mediaId         String
  checkType       MediaCheckType
  resultStatus    MediaCheckResult
  confidenceScore Decimal?         @db.Decimal(5, 4)
  checkedAt       DateTime         @default(now())

  media AlbumPhoto @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([mediaId])
  @@index([checkType])
  @@index([resultStatus])
}
