generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  PARENT
  FAMILY_MEMBER
}

enum Plan {
  FREE
  BASIC
  PREMIUM
}

enum WalletType {
  JOINT
  PERSONAL
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  TASK_REWARD
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_SUBMITTED
  TASK_APPROVED
  TASK_REJECTED
  TRANSFER_RECEIVED
  MEMBER_JOINED
  CHAT_MESSAGE
  SOS
  MONEY_REQUEST
  MONEY_RESOLVED
  CALENDAR_REMINDER
  ANNOUNCEMENT
  SYSTEM
}

enum AnnouncementType {
  ANNOUNCEMENT
  SUPPORT_REQUEST
}

enum ConversationType {
  GROUP
  PRIVATE
}

enum MessageType {
  TEXT
  IMAGE
  LOCATION
}

enum SosStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
  FALSE_ALARM
}

enum MoneyRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PAST_DUE
}

enum FamilyStatus {
  ACTIVE
  SUSPENDED
  LOCKED
}

enum FamilyProvisionStatus {
  PENDING
  PROVISIONING
  READY
  FAILED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentType {
  SUBSCRIPTION
  WALLET_TOPUP
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String
  avatarUrl    String?
  role         Role     @default(FAMILY_MEMBER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  familyMember             FamilyMember?
  refreshTokens            RefreshToken[]
  passwordResetTokens      PasswordResetToken[]
  notifications            Notification[]
  taskProofs               TaskProof[]
  conversationParticipants ConversationParticipant[]
  sentMessages             Message[]
  sosAlerts                SosAlert[]               @relation("SentSOS")
  resolvedSosAlerts        SosAlert[]               @relation("ResolvedSOS")
  locationShare            LocationShare?
  aiConversation           AiConversation?

  @@index([email])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Family {
  id                    String              @id @default(cuid())
  name                  String
  plan                  Plan                @default(FREE)
  planId                String?
  status                FamilyStatus        @default(ACTIVE)
  statusReason          String?
  lockedAt              DateTime?
  subscriptionStatus    SubscriptionStatus  @default(ACTIVE)
  subscriptionStartedAt DateTime?
  subscriptionExpiresAt DateTime?
  // Onboarding state: chưa active cho đến khi mua gói thành công.
  activatedAt           DateTime?
  // Bước onboarding hiện tại: WORKSPACE_CREATED | PLAN_SELECTED | PAYMENT_VERIFIED | ACTIVE
  onboardingStep        String              @default("WORKSPACE_CREATED")
  stripeCustomerId      String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  subscriptionPlan SubscriptionPlan? @relation(fields: [planId], references: [id])
  members          FamilyMember[]
  wallets          Wallet[]
  tasks            Task[]
  conversations    Conversation[]
  events           FamilyEvent[]
  sosAlerts        SosAlert[]
  moneyRequests    MoneyRequest[]
  albumPhotos      AlbumPhoto[]
  locationShares   LocationShare[]
  payments         Payment[]
  invites          FamilyInvite[]
  announcements    Announcement[]
  provision         FamilyProvision?

  @@index([planId])
  @@index([status])
  @@index([subscriptionStatus, subscriptionExpiresAt])
}

model FamilyProvision {
  id            String                @id @default(cuid())
  familyId      String                @unique
  status        FamilyProvisionStatus @default(PENDING)
  containerName String?
  databaseName  String?
  imageTag      String?
  metadata      Json?
  lastError     String?
  provisionedAt DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([status])
}

model FamilyInvite {
  id        String    @id @default(cuid())
  code      String    @unique
  familyId  String
  role      Role
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([code, expiresAt, usedAt])
}

model SubscriptionPlan {
  id                String   @id @default(cuid())
  code              String   @unique
  name              String
  description       String?
  price             Decimal  @default(0) @db.Decimal(12, 2)
  priceMonthly      Decimal? @db.Decimal(12, 2)
  priceYearly       Decimal? @db.Decimal(12, 2)
  currency          String   @default("VND")
  billingPeriod     String   @default("MONTHLY")
  // Thời hạn sử dụng tính theo ngày (vd: 30, 90, 365). null = vô thời hạn (LIFETIME).
  durationDays      Int?
  // Giới hạn tài nguyên
  maxMembers        Int?
  maxTasksPerMonth  Int?
  // Dung lượng (MB). null = không giới hạn.
  albumStorageMb    Int?
  systemStorageMb   Int?
  // Quyền sử dụng AI: tổng quát + AI tài chính (gói cao mới có)
  aiEnabled         Boolean  @default(false)
  aiFinanceEnabled  Boolean  @default(false)
  // Trợ lý lập kế hoạch tài chính nâng cao
  advancedReports   Boolean  @default(false)
  prioritySupport   Boolean  @default(false)
  // Bậc gói: 0 = free, 1 = basic, 2 = standard, 3 = premium...
  tier              Int      @default(0)
  features          Json     @default("[]")
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  families Family[]

  @@index([isActive, sortOrder])
}

model FamilyMember {
  id       String   @id @default(cuid())
  userId   String   @unique
  familyId String
  nickname String?
  isOwner  Boolean  @default(false)
  joinedAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  family       Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  wallet       Wallet?       @relation("PersonalWallet")
  assignedTasks Task[]       @relation("AssignedTasks")
  createdTasks  Task[]       @relation("CreatedTasks")
  createdEvents FamilyEvent[]
  moneyRequests         MoneyRequest[] @relation("RequestedMoney")
  resolvedMoneyRequests MoneyRequest[] @relation("ResolvedMoneyRequest")
  uploadedAlbumPhotos   AlbumPhoto[]
  announcements         Announcement[]

  @@index([familyId])
}

model Wallet {
  id        String     @id @default(cuid())
  familyId  String
  name      String
  type      WalletType
  balance   Decimal    @default(0) @db.Decimal(15, 2)
  currency  String     @default("VND")
  ownerId   String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  family               Family        @relation(fields: [familyId], references: [id])
  owner                FamilyMember? @relation("PersonalWallet", fields: [ownerId], references: [id])
  sentTransactions     Transaction[] @relation("FromWallet")
  receivedTransactions Transaction[] @relation("ToWallet")

  @@index([familyId])
}

model Transaction {
  id           String          @id @default(cuid())
  fromWalletId String?
  toWalletId   String?
  amount       Decimal         @db.Decimal(15, 2)
  type         TransactionType
  description  String?
  taskId       String?
  createdAt    DateTime        @default(now())

  fromWallet Wallet? @relation("FromWallet", fields: [fromWalletId], references: [id])
  toWallet   Wallet? @relation("ToWallet", fields: [toWalletId], references: [id])
  task       Task?   @relation(fields: [taskId], references: [id])

  @@index([fromWalletId])
  @@index([toWalletId])
  @@index([createdAt])
}

model Task {
  id           String     @id @default(cuid())
  familyId     String
  title        String
  description  String?
  status       TaskStatus @default(PENDING)
  reward       Decimal?   @db.Decimal(15, 2)
  dueDate      DateTime?
  createdById  String
  assignedToId String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  family       Family        @relation(fields: [familyId], references: [id])
  createdBy    FamilyMember  @relation("CreatedTasks", fields: [createdById], references: [id])
  assignedTo   FamilyMember? @relation("AssignedTasks", fields: [assignedToId], references: [id])
  proofs       TaskProof[]
  transactions Transaction[]

  @@index([familyId, status])
  @@index([assignedToId])
}

model TaskProof {
  id          String   @id @default(cuid())
  taskId      String
  submittedBy String
  imageUrl    String?
  note        String?
  createdAt   DateTime @default(now())

  task      Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  submitter User @relation(fields: [submittedBy], references: [id])

  @@index([taskId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model Conversation {
  id        String           @id @default(cuid())
  familyId  String
  type      ConversationType @default(GROUP)
  name      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  family       Family                   @relation(fields: [familyId], references: [id])
  participants ConversationParticipant[]
  messages     Message[]

  @@index([familyId])
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime @default(now())
  joinedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  senderId       String
  type           MessageType @default(TEXT)
  content        String
  metadata       Json?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
}

model FamilyEvent {
  id          String    @id @default(cuid())
  familyId    String
  createdById String
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  allDay       Boolean   @default(false)
  color        String    @default("#3b82f6")
  reminderSent Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  family    Family       @relation(fields: [familyId], references: [id])
  createdBy FamilyMember @relation(fields: [createdById], references: [id])

  @@index([familyId, startDate])
}

model SosAlert {
  id           String    @id @default(cuid())
  familyId     String
  senderId     String
  latitude     Float?
  longitude    Float?
  address      String?
  message      String?
  status       SosStatus @default(ACTIVE)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  resolvedAt   DateTime?
  resolvedById String?

  family     Family @relation(fields: [familyId], references: [id])
  sender     User   @relation("SentSOS", fields: [senderId], references: [id])
  resolvedBy User?  @relation("ResolvedSOS", fields: [resolvedById], references: [id])

  @@index([familyId, status])
  @@index([senderId])
  @@index([createdAt])
}

model MoneyRequest {
  id           String             @id @default(cuid())
  familyId     String
  requesterId  String
  amount       Decimal            @db.Decimal(15, 2)
  reason       String?
  status       MoneyRequestStatus @default(PENDING)
  note         String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  resolvedAt   DateTime?
  resolvedById String?

  family     Family       @relation(fields: [familyId], references: [id])
  requester  FamilyMember @relation("RequestedMoney", fields: [requesterId], references: [id])
  resolvedBy FamilyMember? @relation("ResolvedMoneyRequest", fields: [resolvedById], references: [id])

  @@index([familyId, status])
  @@index([requesterId])
  @@index([createdAt])
}

model AiConversation {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AiMessage[]
}

model AiMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String
  tokensUsed     Int?
  model          String?
  createdAt      DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model LocationShare {
  id         String   @id @default(cuid())
  userId     String   @unique
  familyId   String
  isSharing  Boolean  @default(false)
  latitude   Float?
  longitude  Float?
  accuracy   Float?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId, isSharing])
}

model Payment {
  id                String        @id @default(cuid())
  familyId          String
  userId            String
  type              PaymentType
  amount            Decimal       @db.Decimal(15, 2)
  currency          String        @default("VND")
  status            PaymentStatus @default(PENDING)
  provider          String        @default("MOCK")
  providerReference String?
  description       String?
  metadata          Json?
  planId            String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId, createdAt])
  @@index([status, type])
  @@index([createdAt])
}

model AlbumPhoto {
  id         String   @id @default(cuid())
  familyId   String
  uploaderId String
  imageUrl   String
  caption    String?
  createdAt  DateTime @default(now())

  family   Family       @relation(fields: [familyId], references: [id])
  uploader FamilyMember @relation(fields: [uploaderId], references: [id])

  @@index([familyId, createdAt])
  @@index([uploaderId])
}

model Announcement {
  id         String           @id @default(cuid())
  familyId   String
  senderId   String
  type       AnnouncementType @default(ANNOUNCEMENT)
  content    String
  createdAt  DateTime         @default(now())

  family Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  sender FamilyMember @relation(fields: [senderId], references: [id])

  @@index([familyId, createdAt])
  @@index([senderId])
}
